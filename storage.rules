rules_version = '2';

// Firebase Storage Rules for Bundles
// This is SEPARATE from Firestore rules!
service firebase.storage {
  match /b/{bucket}/o {
    
    // Bundles folder - authenticated users can read, admins can write
    match /bundles/{fileName} {
      // Anyone authenticated can read bundles (for game loading)
      allow read: if request.auth != null;
      
      // Only authenticated users can write (admin check happens in client)
      // Ideally you'd check admin role here too, but Storage doesn't have easy access to Firestore
      allow write: if request.auth != null;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
