rules_version = '2';

// Firebase Storage Rules for Bundles
// This is SEPARATE from Firestore rules!
service firebase.storage {
  match /b/{bucket}/o {
    
    // Bundles folder - authenticated users can read, only admins can write
    match /bundles/{fileName} {
      // Anyone authenticated can read bundles (for game loading)
      allow read: if request.auth != null;

      // Only admins can write bundles (requires custom claim set via Admin SDK)
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
