{
  "compilerOptions": {
    "module": "es2022",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "./*": ["./www/*"]
    }
  },
  "include": ["www/**/*.js"],
  "exclude": ["node_modules", "android", ".firebase", "tests"]
}
