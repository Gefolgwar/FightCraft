                                        L.polygon(latLngs, {
                                            color: "#eab308",
                                            weight: 2,
                                            fillOpacity: 0.1,
                                            fillColor: "#eab308",
                                            interactive: true,
                                        })
                                            .bindPopup(
                                                `<div class="text-xs"><b>${f.properties.name || f.properties.id || "Zone"}</b></div>`,
                                            )
                                            .addTo(districtLayerGroup);
                                    });

                                    // Yield to UI every 500 zones
                                    if (vi % 500 === 0 && vi > 0) {
                                        status.textContent = `Rendering zones ${vi}/${features.length}...`;
                                        await new Promise((r) =>
                                            setTimeout(r, 5),
                                        );
                                    }
                                }
                            }

                            status.textContent = `Rendered ${voronoiPolygons?.features?.length || 0} global Voronoi zones.`;
                        } catch (e) {
                            console.warn("Global Voronoi error", e);
                        }
                    }

                    if (bounds.isValid()) {
