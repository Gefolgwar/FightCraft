                                        lng: coord[0],
                                    })),
                                    center: {
                                        lat: coords[0][0][1],
                                        lng: coords[0][0][0],
                                    },
                                });
                            }
                        } else if (type === "MultiPolygon") {
                            coords.forEach((polyCoords) => {
                                if (polyCoords.length > 0) {
                                    zones.push({
                                        name:
                                            "Zone " +
                                            (f.properties.citadelId
                                                ? f.properties.citadelId.substr(
