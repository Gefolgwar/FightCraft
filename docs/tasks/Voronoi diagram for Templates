                    bar.style.width = "5%";

                    // Dynamically import WORLD_CITIES
                    const { WORLD_CITIES } =
                        await import("../gameplay/world_cities.js");

                    status.textContent = "Fetching templates from database...";
                    bar.style.width = "10%";
                    const allCastles = await getTemplates("castle");
                    let citadelsTemplates = allCastles.filter(
                        (t) =>
                            t.icon === "🏯" ||
                            (t.name && t.name.includes("Citadel")) ||
                            (t.id && t.id.includes("citadel")),
                    );

                    if (citadelsTemplates.length === 0) {
