                                            finalCitadels.map((c) =>
                                                window.turf.point(
                                                    [c.lng, c.lat],
                                                    {
                                                        id: c.id,
                                                        name: c.name,
                                                        cityId: c.cityId,
                                                    },
                                                ),
                                            ),
                                        );
                                    const options = {
                                        bbox: [
                                            cityBounds.minLng,
                                            cityBounds.minLat,
                                            cityBounds.maxLng,
                                            cityBounds.maxLat,
                                        ],
                                    };
                                    const voronoiPolygons = window.turf.voronoi(
                                        points,
                                        options,
                                    );

                                    // Match Voronoi cells to citadels
                                    if (
                                        voronoiPolygons &&
                                        voronoiPolygons.features
                                    ) {
                                        voronoiPolygons.features.forEach(
                                            (polygon, idx) => {
                                                if (!polygon) return;
                                                let matchedCitadel =
                                                    points.features.find(
                                                        (pt) => {
                                                            try {
                                                                return window.turf.booleanPointInPolygon(
                                                                    pt,
                                                                    polygon,
                                                                );
                                                            } catch {
                                                                return false;
                                                            }
                                                        },
                                                    );

                                                if (!matchedCitadel) {
                                                    try {
                                                        const centroid =
                                                            window.turf.centroid(
                                                                polygon,
                                                            );
                                                        matchedCitadel =
                                                            window.turf.nearestPoint(
                                                                centroid,
                                                                points,
                                                            );
                                                    } catch {
                                                        matchedCitadel =
                                                            points.features[
                                                                idx
                                                            ];
                                                    }
                                                }

                                                if (matchedCitadel) {
                                                    polygon.properties = {
                                                        ...matchedCitadel.properties,
                                                    };
                                                }
                                            },
                                        );
                                    }

