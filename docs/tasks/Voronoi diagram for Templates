                        city.name,
                        { lat: city.lat, lng: city.lng },
                    );
                    adminDistrictCache[cityId] = context;
                    if (context.boundary) renderCityBoundary(context.boundary);
                    if (context.boundary)
                        logConsole(
                            `✅ City metadata synchronized from OpenStreetMap.`,
