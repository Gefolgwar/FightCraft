                                        window.turf.featureCollection(
                                            finalCitadels.map((c) =>
                                                window.turf.point(
                                                    [c.lng, c.lat],
                                                    {
                                                        id: c.id,
                                                        name: c.name,
                                                        cityId: c.cityId,
                                                    },
                                                ),
                                            ),
                                        );
