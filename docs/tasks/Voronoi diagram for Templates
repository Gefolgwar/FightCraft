            // Init
            document.addEventListener("DOMContentLoaded", async () => {
                await initFirebase();

                bulkActions = new BulkActions(deleteSnapshot, loadSnapshots);

                if (!isAdmin()) {
                    document
                        .getElementById("admin-lock")
