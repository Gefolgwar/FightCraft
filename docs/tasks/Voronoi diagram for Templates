                    } else if (objectType === "monster") {
                        iconHtml = `<div class="flex items-center justify-center w-8 h-8 text-2xl filter drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] select-none">
                                                ${iconChar}
                                            </div>`;
