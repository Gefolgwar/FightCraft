                                </div>
                                `
                                        : ""
                                }
                            </div>
                        `;

                document.getElementById("snap-details").innerHTML = detailsHtml;
                if (
                    monsterDist.length > 0 ||
                    shopDist.length > 0 ||
                    castleDist.length > 0
