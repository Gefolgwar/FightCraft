                                        <span class="text-gray-400">#${obj.id || "Template"}</span><br>
                                        <hr class="my-1 border-gray-700">
                                        <span class="text-gray-300">Type: ${objectType}</span><br>
                                        <code class="text-blue-300">${lat.toFixed(6)}, ${lng.toFixed(6)}</code>
