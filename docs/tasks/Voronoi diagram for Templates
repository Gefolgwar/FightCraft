                console.log(
                    `🏙️ Fetching city boundary for visual reference: ${city.name}`,
                );
                try {
                    const boundaryPoints =
                        await OverpassService.fetchCityBoundary(city.name, {
                            lat: city.lat,
                            lng: city.lng,
