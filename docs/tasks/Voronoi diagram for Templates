                const user = getCurrentUser();
                document.getElementById("admin-status").innerHTML =
                    `<span class="text-green-400">● Online (${user ? user.email : "test@admin.com"})</span>`;

                initMap();

                // Attach global preview listener
                const btnGlobal = document.getElementById("btn-preview-global");
                if (btnGlobal) {
                    btnGlobal.addEventListener("click", previewGlobalWorld);
