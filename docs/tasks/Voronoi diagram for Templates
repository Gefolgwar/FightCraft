                    const typesPresent = new Set();
                    let hasCitadel = false;
                    let hasCastle = false;

                    if (snap.objects && snap.objects.length > 0) {
                        snap.objects.forEach((o) => {
                            if (o.type === "castle") {
                                if (
                                    o.icon === "🏯" ||
                                    (o.name && o.name.includes("Citadel"))
