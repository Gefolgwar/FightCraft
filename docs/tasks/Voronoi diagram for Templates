                            let minLng = Infinity,
                                minLat = Infinity,
                                maxLng = -Infinity,
                                maxLat = -Infinity;
                            allGeneratedCitadels.forEach((c) => {
                                if (c.lng < minLng) minLng = c.lng;
                                if (c.lat < minLat) minLat = c.lat;
                                if (c.lng > maxLng) maxLng = c.lng;
                                if (c.lat > maxLat) maxLat = c.lat;
                            });
                            const padLng = (maxLng - minLng) * 0.05 || 0.01;
                            const padLat = (maxLat - minLat) * 0.05 || 0.01;
                            const globalBbox = [
                                minLng - padLng,
                                minLat - padLat,
                                maxLng + padLng,
                                maxLat + padLat,
                            ];

                            const voronoiPolygons = window.turf.voronoi(
