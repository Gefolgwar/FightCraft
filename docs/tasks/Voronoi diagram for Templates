                document.getElementById("selected-snap-title").textContent =
                    snap.name ||
                    `${snap.cityId.toUpperCase()} - ${new Date(snap.created).toLocaleTimeString()}`;
                // Calculate Stats
                const counts = {
                    monster: 0,
                    shop: 0,
                    vault: 0,
                    castle: 0,
                    citadel: 0,
                    other: 0,
                };
                const levels = { min: 999, max: 0, avg: 0, sum: 0 };
