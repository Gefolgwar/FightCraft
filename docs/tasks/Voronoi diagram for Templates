            async function previewGlobalWorld() {
                const btn = document.getElementById("btn-preview-global");
                const container = document.getElementById(
                    "preview-progress-container",
                );
                const status = document.getElementById("preview-status");
                const bar = document.getElementById("preview-progress-bar");

                btn.disabled = true;
                btn.classList.add("opacity-50", "cursor-not-allowed");
                container.classList.remove("hidden");

                try {
                    status.textContent = "Loading world cities dataset...";
                    bar.style.width = "5%";

                    // Dynamically import WORLD_CITIES
                    const { WORLD_CITIES } =
                        await import("../gameplay/world_cities.js");

                    status.textContent = "Fetching templates from database...";
                    bar.style.width = "10%";
                    const allCastles = await getTemplates("castle");
                    let citadelsTemplates = allCastles.filter(
                        (t) =>
                            t.icon === "🏯" ||
                            (t.name && t.name.includes("Citadel")) ||
                            (t.id && t.id.includes("citadel")),
                    );

                    if (citadelsTemplates.length === 0) {
                        citadelsTemplates = [
                            {
                                id: "citadel_fallback",
                                name: "Citadel",
                                icon: "🏯",
                                level: 15,
                                type: "castle",
                            },
                        ];
                    }

                    // Clear previous snapshot
                    currentSnapshot = null;
                    document.getElementById("selected-snap-title").innerHTML =
                        `<span>Preview: Global World</span>`;
                    document.getElementById("snap-details").innerHTML =
                        `<div class="p-2 text-xs text-gray-300 space-y-2"><p>Showing deterministically generated zones and citadels globally (${WORLD_CITIES.length} cities). <b>Read-only preview.</b></p></div>`;

                    if (markerClusterGroup) markerClusterGroup.clearLayers();
                    if (markerLayerGroup) markerLayerGroup.clearLayers();
                    if (districtLayerGroup) districtLayerGroup.clearLayers();
                    if (cityBoundaryLayerGroup)
                        cityBoundaryLayerGroup.clearLayers();

                    const bounds = L.latLngBounds();
                    let totalCitadels = 0;
                    let allGeneratedCitadels = [];

                    for (let i = 0; i < WORLD_CITIES.length; i++) {
                        const city = WORLD_CITIES[i];

                        if (i % 10 === 0) {
                            status.textContent = `Calculating positions for ${city.name} (${i + 1}/${WORLD_CITIES.length})...`;
                            bar.style.width = `${10 + (i / WORLD_CITIES.length) * 90}%`;
                            await new Promise((r) => setTimeout(r, 10)); // allow UI update
                        }

                        // Generate a synthetic boundary based on population
                        // Assume ~10km radius for 1M population, scaled by sqrt
                        const population = city.population || 500000;
                        const radiusMeters = Math.max(
                            3000,
                            Math.sqrt(population) * 10,
                        );

                        // Create a turf circle for the city boundary
                        const center = [city.lng, city.lat];
                        const options = { steps: 32, units: "meters" };
                        let cityBoundary;
                        try {
                            if (window.turf) {
                                cityBoundary = window.turf.circle(
                                    center,
                                    radiusMeters,
                                    options,
                                );
                            }
                        } catch (e) {
                            console.warn("Turf error", e);
                        }

                        // We do not call Overpass! We use synthetic generation only.
                        const targetCitadels = Math.max(
                            1,
                            Math.round(population / 200000),
                        );

                        const processedCitadels = [];
                        let attempts = 0;
                        const cityBounds = {
                            minLat: city.lat - radiusMeters / 111320,
                            maxLat: city.lat + radiusMeters / 111320,
                            minLng:
                                city.lng -
                                radiusMeters /
                                    (111320 *
                                        Math.cos((city.lat * Math.PI) / 180)),
                            maxLng:
                                city.lng +
                                radiusMeters /
                                    (111320 *
                                        Math.cos((city.lat * Math.PI) / 180)),
                        };

                        const citadelTemplate =
                            citadelsTemplates.length > 0
                                ? citadelsTemplates[
                                      Math.floor(
                                          Math.random() *
                                              citadelsTemplates.length,
                                      )
                                  ]
                                : null;

                        while (
                            processedCitadels.length < targetCitadels &&
                            attempts < 500
                        ) {
                            attempts++;
                            const lat =
                                cityBounds.minLat +
                                Math.random() *
                                    (cityBounds.maxLat - cityBounds.minLat);
                            const lng =
                                cityBounds.minLng +
                                Math.random() *
                                    (cityBounds.maxLng - cityBounds.minLng);

                            let isInside = true;
                            if (cityBoundary && window.turf) {
                                try {
                                    isInside =
                                        window.turf.booleanPointInPolygon(
                                            [lng, lat],
                                            cityBoundary,
                                        );
                                } catch (e) {
                                    isInside = true;
                                }
                            }

                            if (isInside && citadelTemplate) {
                                processedCitadels.push({
                                    id: `${city.id}_citadel_${Math.random().toString(36).substring(2, 9)}`,
                                    type: "castle",
                                    cityId: city.id,
                                    lat,
                                    lng,
                                    templateId: citadelTemplate.id,
                                    name: `${city.name} Citadel ${processedCitadels.length + 1}`,
                                    icon: citadelTemplate.icon,
                                    level: citadelTemplate.level || 15,
                                    hp: (citadelTemplate.level || 15) * 200,
                                    maxHp: (citadelTemplate.level || 15) * 200,
                                });
                            }
                        }

                        const finalCitadels = processedCitadels;
                        totalCitadels += finalCitadels.length;
                        allGeneratedCitadels.push(...finalCitadels);

                        // Render City Boundary
                        if (cityBoundary && visibility.cityBoundary) {
                            try {
                                const coords =
                                    cityBoundary.geometry.coordinates[0];
                                const latLngs = coords.map((c) => [c[1], c[0]]);
                                L.polygon(latLngs, {
                                    color: "#10b981",
                                    weight: 2,
                                    dashArray: "5, 10",
                                    fillOpacity: 0.05,
                                    interactive: false,
                                }).addTo(cityBoundaryLayerGroup);
                            } catch (e) {
                                console.error(
                                    `Error rendering boundary for ${city.name}:`,
                                    e,
                                );
                            }
                        }

                        // Use simple Voronoi for zones if Turf is available
                        let zonesGeoJson = null;
                        if (
                            finalCitadels.length > 0 &&
                            window.turf &&
                            visibility.district
                        ) {
                            try {
                                if (finalCitadels.length === 1) {
                                    if (cityBoundary) {
                                        let singleZone = JSON.parse(
                                            JSON.stringify(cityBoundary),
                                        );
                                        singleZone.properties = {
                                            id: finalCitadels[0].id,
                                            name: finalCitadels[0].name,
                                            cityId: finalCitadels[0].cityId,
                                        };
                                        zonesGeoJson =
                                            window.turf.featureCollection([
                                                singleZone,
                                            ]);
                                    }
                                } else {
                                    const points =
                                        window.turf.featureCollection(
                                            finalCitadels.map((c) =>
                                                window.turf.point(
                                                    [c.lng, c.lat],
                                                    {
                                                        id: c.id,
                                                        name: c.name,
                                                        cityId: c.cityId,
                                                    },
                                                ),
                                            ),
                                        );
                                    const options = {
                                        bbox: [
                                            cityBounds.minLng,
                                            cityBounds.minLat,
                                            cityBounds.maxLng,
                                            cityBounds.maxLat,
                                        ],
                                    };
                                    const voronoiPolygons = window.turf.voronoi(
                                        points,
                                        options,
                                    );

                                    // Match Voronoi cells to citadels
                                    if (
                                        voronoiPolygons &&
                                        voronoiPolygons.features
                                    ) {
                                        voronoiPolygons.features.forEach(
                                            (polygon, idx) => {
                                                if (!polygon) return;
                                                let matchedCitadel =
                                                    points.features.find(
                                                        (pt) => {
                                                            try {
                                                                return window.turf.booleanPointInPolygon(
                                                                    pt,
                                                                    polygon,
                                                                );
                                                            } catch {
                                                                return false;
                                                            }
                                                        },
                                                    );

                                                if (!matchedCitadel) {
                                                    try {
                                                        const centroid =
                                                            window.turf.centroid(
                                                                polygon,
                                                            );
                                                        matchedCitadel =
                                                            window.turf.nearestPoint(
                                                                centroid,
                                                                points,
                                                            );
                                                    } catch {
                                                        matchedCitadel =
                                                            points.features[
                                                                idx
                                                            ];
                                                    }
                                                }

                                                if (matchedCitadel) {
                                                    polygon.properties = {
                                                        ...matchedCitadel.properties,
                                                    };
                                                }
                                            },
                                        );
                                    }

                                    // Intersect with city boundary
                                    if (
                                        cityBoundary &&
                                        voronoiPolygons &&
                                        voronoiPolygons.features
                                    ) {
                                        const intersectedFeatures = [];
                                        window.turf.featureEach(
                                            voronoiPolygons,
                                            (currentFeature) => {
                                                if (!currentFeature) return;
                                                try {
                                                    const intersection =
                                                        window.turf.intersect(
                                                            currentFeature,
                                                            cityBoundary,
                                                        );
                                                    if (intersection) {
                                                        intersection.properties =
                                                            currentFeature.properties;
                                                        intersectedFeatures.push(
                                                            intersection,
                                                        );
                                                    }
                                                } catch (e) {}
                                            },
                                        );
                                        zonesGeoJson =
                                            window.turf.featureCollection(
                                                intersectedFeatures,
                                            );
                                    } else {
                                        zonesGeoJson = voronoiPolygons;
                                    }
                                }
                            } catch (e) {
                                console.warn("Voronoi error", e);
                            }
                        }

                        // Render Zones
                        if (zonesGeoJson && visibility.district) {
                            zonesGeoJson.features.forEach((f) => {
                                if (!f || !f.geometry) return;

                                // Handle Polygon vs MultiPolygon properly
                                const polys =
                                    f.geometry.type === "Polygon"
                                        ? [f.geometry.coordinates]
                                        : f.geometry.type === "MultiPolygon"
                                          ? f.geometry.coordinates
                                          : [];

                                polys.forEach((coords) => {
                                    if (!coords || !coords[0]) return;
                                    const latLngs = coords[0].map((c) => [
                                        c[1],
                                        c[0],
                                    ]);
                                    L.polygon(latLngs, {
                                        color: "#eab308",
                                        weight: 2,
                                        fillOpacity: 0.1,
                                        fillColor: "#eab308",
                                        interactive: true,
                                    })
                                        .bindPopup(
                                            `<div class="text-xs"><b>${f.properties.name || f.properties.id || "Zone"}</b></div>`,
                                        )
                                        .addTo(districtLayerGroup);
                                });
                            });
                        }

                        // Render Citadels
                        if (visibility.citadel) {
                            const markersToCluster = [];
                            finalCitadels.forEach((c) => {
                                const latLng = [c.lat, c.lng];
                                bounds.extend(latLng);

                                const iconHtml = `
                                    <div class="w-12 h-12 flex items-center justify-center relative bg-transparent">
                                        <div class="absolute inset-0 rounded-full blur-md opacity-60 bg-cyan-500"></div>
                                        <div class="text-3xl filter drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] z-10 leading-none select-none">${c.icon || "🏯"}</div>
                                    </div>
                                `;
                                const markerIcon = L.divIcon({
                                    html: iconHtml,
                                    className: "custom-tpl-icon",
                                    iconSize: [48, 48],
                                    iconAnchor: [24, 24],
                                });
                                const m = L.marker(latLng, {
                                    icon: markerIcon,
                                    zIndexOffset: 3000,
                                }).bindPopup(
                                    `<div class="text-xs p-1">
                                        <b class="text-sm text-cyan-400">${c.name}</b><br>
                                        <span class="text-gray-400">#${c.id}</span><br>
                                        <hr class="my-1 border-gray-700">
                                        <code class="text-blue-300">${c.lat.toFixed(5)}, ${c.lng.toFixed(5)}</code><br>
                                        <span class="text-[10px] text-gray-500">Source: Deterministic Generator</span>
                                    </div>`,
                                );
                                markersToCluster.push(m);
                            });
                            if (markersToCluster.length > 0) {
                                markerClusterGroup.addLayers(markersToCluster);
                            }
                        }
                    }

                    if (bounds.isValid()) {
                        map.fitBounds(bounds, { padding: [50, 50] });
                    }

                    // Save local snapshot
                    const localData = {
                        id: "local_" + Date.now(),
                        name:
                            "Global Map Run " + new Date().toLocaleTimeString(),
                        created: Date.now(),
                        cityId: "GLOBAL",
                        type: "global_preview",
                        objects: allGeneratedCitadels,
                        citiesCount: WORLD_CITIES.length,
                        isLocal: true,
                    };

                    try {
                        await LocalSnapshotsManager.saveSnapshot(localData);
                        logConsole(
                            "Saved local snapshot to IndexedDB. Database not overloaded.",
                        );
                        // Re-trigger render
                        const firestoreSnaps = await getWorldSnapshots();
                        await mergeAndRenderSnapshots(firestoreSnaps);
                    } catch (e) {
                        console.error("Failed to save local snapshot", e);
                        logConsole(
                            "Failed to save local snapshot: " + e.message,
                        );
                    }

                    bar.style.width = "100%";
                    status.textContent = `Preview complete (${totalCitadels} citadels globally)`;
                } catch (error) {
                    console.error("Preview Error:", error);
                    status.textContent = `Error: ${error.message}`;
                } finally {
                    btn.disabled = false;
                    btn.classList.remove("opacity-50", "cursor-not-allowed");
                    setTimeout(() => {
                        container.classList.add("hidden");
                        bar.style.width = "0%";
                    }, 5000);
                }
            }

            async function selectSnapshot(snap) {
                if (snap.type === "global_preview") {
                    currentSnapshot = snap;
                    document
                        .querySelectorAll("#snapshot-list > div")
                        .forEach((el) =>
                            el.classList.remove(
                                "border-blue-500",
                                "bg-gray-800",
                            ),
                        );
                    const activeEl = document.getElementById(`snap-${snap.id}`);
                    if (activeEl)
                        activeEl.classList.add(
                            "border-blue-500",
                            "bg-gray-800",
                        );

                    document.getElementById("selected-snap-title").innerHTML =
                        `<span class="text-emerald-400">Local Generated Preview</span>`;
                    document.getElementById("snap-details").innerHTML =
                        `<div class="p-2 text-xs text-gray-300">
                        <p><b>Name:</b> ${snap.name}</p>
                        <p><b>Cities Processed:</b> ${snap.citiesCount}</p>
                        <p><b>Total Citadels:</b> ${snap.objects.length}</p>
                        <p class="mt-2 text-gray-500 italic">This is a saved local generation. Geometry is approximated from citadels list.</p>
                    </div>`;

                    if (markerClusterGroup) markerClusterGroup.clearLayers();
                    if (markerLayerGroup) markerLayerGroup.clearLayers();
                    if (districtLayerGroup) districtLayerGroup.clearLayers();
                    if (cityBoundaryLayerGroup)
                        cityBoundaryLayerGroup.clearLayers();

                    const bounds = L.latLngBounds();
                    const markersToCluster = [];

                    const citadelsByCity = {};

                    snap.objects.forEach((c) => {
                        if (!citadelsByCity[c.cityId])
                            citadelsByCity[c.cityId] = [];
                        citadelsByCity[c.cityId].push(c);

                        const latLng = [c.lat, c.lng];
                        bounds.extend(latLng);
                        const iconHtml = `
                            <div class="w-12 h-12 flex items-center justify-center relative bg-transparent">
                                <div class="absolute inset-0 rounded-full blur-md opacity-60 bg-cyan-500"></div>
                                <div class="text-3xl filter drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)] z-10 leading-none select-none">${c.icon || "🏯"}</div>
                            </div>
                        `;
                        const markerIcon = L.divIcon({
                            html: iconHtml,
                            className: "custom-tpl-icon",
                            iconSize: [48, 48],
                            iconAnchor: [24, 24],
                        });
                        const m = L.marker(latLng, {
                            icon: markerIcon,
                            zIndexOffset: 3000,
                        }).bindPopup(
                            `<div class="text-xs p-1">
                                <b class="text-sm text-cyan-400">${c.name}</b><br>
                                <span class="text-gray-400">#${c.id}</span><br>
                                <hr class="my-1 border-gray-700">
                                <code class="text-blue-300">${c.lat.toFixed(5)}, ${c.lng.toFixed(5)}</code><br>
                                <span class="text-[10px] text-gray-500">Source: Local Saved Generation</span>
                            </div>`,
                        );
                        markersToCluster.push(m);
                    });

                    if (
                        typeof visibility !== "undefined" &&
                        visibility.citadel &&
                        markersToCluster.length > 0
                    ) {
                        markerClusterGroup.addLayers(markersToCluster);
                    } else if (markersToCluster.length > 0) {
                        markerClusterGroup.addLayers(markersToCluster);
                    }

                    if (bounds.isValid()) {
                        map.fitBounds(bounds, { padding: [50, 50] });
                    }

                    // Asynchronously generate and render Voronoi zones & City Boundaries
                    (async () => {
                        if (!window.turf) return;

                        document.getElementById("snap-details").innerHTML +=
                            `<div id="recalc-status" class="mt-2 text-[10px] font-bold text-yellow-400 animate-pulse">Recalculating Zones... 0%</div>`;

                        const { WORLD_CITIES } =
                            await import("../gameplay/world_cities.js");
                        const citiesMap = {};
                        WORLD_CITIES.forEach((c) => (citiesMap[c.id] = c));

                        const cityIds = Object.keys(citadelsByCity);
                        for (let i = 0; i < cityIds.length; i++) {
                            const cityId = cityIds[i];
                            const city = citiesMap[cityId];
                            if (!city) continue;

                            const finalCitadels = citadelsByCity[cityId];

                            // 1. City Boundary
                            const population = city.population || 500000;
                            const radiusMeters = Math.max(
                                3000,
                                Math.sqrt(population) * 10,
                            );
                            const center = [city.lng, city.lat];
                            const options = { steps: 32, units: "meters" };

                            let cityBoundary = null;
                            try {
                                cityBoundary = window.turf.circle(
                                    center,
                                    radiusMeters,
                                    options,
                                );
                            } catch (e) {}

                            if (
                                cityBoundary &&
                                typeof visibility !== "undefined" &&
                                visibility.cityBoundary
                            ) {
                                const coords =
                                    cityBoundary.geometry.coordinates[0];
                                const latLngs = coords.map((c) => [c[1], c[0]]);
                                L.polygon(latLngs, {
                                    color: "#10b981",
                                    weight: 2,
                                    dashArray: "5, 10",
                                    fillOpacity: 0.05,
                                    interactive: false,
                                }).addTo(cityBoundaryLayerGroup);
                            }

                            // 2. Voronoi Zones
                            if (
                                finalCitadels.length > 0 &&
                                typeof visibility !== "undefined" &&
                                visibility.district
                            ) {
                                const cityBounds = {
                                    minLat: city.lat - radiusMeters / 111320,
                                    maxLat: city.lat + radiusMeters / 111320,
                                    minLng:
                                        city.lng -
                                        radiusMeters /
                                            (111320 *
                                                Math.cos(
                                                    (city.lat * Math.PI) / 180,
                                                )),
                                    maxLng:
                                        city.lng +
                                        radiusMeters /
                                            (111320 *
                                                Math.cos(
                                                    (city.lat * Math.PI) / 180,
                                                )),
                                };

                                try {
                                    let zonesGeoJson = null;

                                    if (finalCitadels.length === 1) {
                                        if (cityBoundary) {
                                            let singleZone = JSON.parse(
                                                JSON.stringify(cityBoundary),
                                            );
                                            singleZone.properties = {
                                                id: finalCitadels[0].id,
                                                name: finalCitadels[0].name,
                                                cityId: finalCitadels[0].cityId,
                                            };
                                            zonesGeoJson =
                                                window.turf.featureCollection([
                                                    singleZone,
                                                ]);
                                        }
                                    } else {
                                        const points =
                                            window.turf.featureCollection(
                                                finalCitadels.map((c) =>
                                                    window.turf.point(
                                                        [c.lng, c.lat],
                                                        {
                                                            id: c.id,
                                                            name: c.name,
                                                            cityId: c.cityId,
                                                        },
                                                    ),
                                                ),
                                            );

                                        const voronoiPolygons =
                                            window.turf.voronoi(points, {
                                                bbox: [
                                                    cityBounds.minLng,
                                                    cityBounds.minLat,
                                                    cityBounds.maxLng,
                                                    cityBounds.maxLat,
                                                ],
                                            });

                                        // Match Voronoi cells to citadels
                                        if (
                                            voronoiPolygons &&
                                            voronoiPolygons.features
                                        ) {
                                            voronoiPolygons.features.forEach(
                                                (polygon, idx) => {
                                                    if (!polygon) return;
                                                    let matchedCitadel =
                                                        points.features.find(
                                                            (pt) => {
                                                                try {
                                                                    return window.turf.booleanPointInPolygon(
                                                                        pt,
                                                                        polygon,
                                                                    );
                                                                } catch {
                                                                    return false;
                                                                }
                                                            },
                                                        );

                                                    if (!matchedCitadel) {
                                                        try {
                                                            const centroid =
                                                                window.turf.centroid(
                                                                    polygon,
                                                                );
                                                            matchedCitadel =
                                                                window.turf.nearestPoint(
                                                                    centroid,
                                                                    points,
                                                                );
                                                        } catch {
                                                            matchedCitadel =
                                                                points.features[
                                                                    idx
                                                                ];
                                                        }
                                                    }

                                                    if (matchedCitadel) {
                                                        polygon.properties = {
                                                            ...matchedCitadel.properties,
                                                        };
                                                    }
                                                },
                                            );
                                        }

                                        if (
                                            cityBoundary &&
                                            voronoiPolygons &&
                                            voronoiPolygons.features
                                        ) {
                                            const intersectedFeatures = [];
                                            window.turf.featureEach(
                                                voronoiPolygons,
                                                (currentFeature) => {
                                                    if (!currentFeature) return;
                                                    try {
                                                        const intersection =
                                                            window.turf.intersect(
                                                                currentFeature,
                                                                cityBoundary,
                                                            );
                                                        if (intersection) {
                                                            intersection.properties =
                                                                currentFeature.properties;
                                                            intersectedFeatures.push(
                                                                intersection,
                                                            );
                                                        }
                                                    } catch (e) {}
                                                },
                                            );
                                            zonesGeoJson =
                                                window.turf.featureCollection(
                                                    intersectedFeatures,
                                                );
                                        } else {
                                            zonesGeoJson = voronoiPolygons;
                                        }
                                    }

                                    if (zonesGeoJson && zonesGeoJson.features) {
                                        zonesGeoJson.features.forEach((f) => {
                                            if (!f || !f.geometry) return;

                                            // Handle Polygon vs MultiPolygon properly
                                            const polys =
                                                f.geometry.type === "Polygon"
                                                    ? [f.geometry.coordinates]
                                                    : f.geometry.type ===
                                                        "MultiPolygon"
                                                      ? f.geometry.coordinates
                                                      : [];

                                            polys.forEach((coords) => {
                                                if (!coords || !coords[0])
                                                    return;
                                                const latLngs = coords[0].map(
                                                    (c) => [c[1], c[0]],
                                                );
                                                L.polygon(latLngs, {
                                                    color: "#eab308",
                                                    weight: 2,
                                                    fillOpacity: 0.1,
                                                    fillColor: "#eab308",
                                                    interactive: true,
                                                })
                                                    .bindPopup(
                                                        `<div class="text-xs"><b>${f.properties.name || f.properties.id || "Zone"}</b></div>`,
                                                    )
                                                    .addTo(districtLayerGroup);
                                            });
                                        });
                                    }
                                } catch (e) {
                                    console.warn(
                                        "Voronoi calc error for " + city.name,
                                        e,
                                    );
                                }
                            }

                            // Yield to UI thread occasionally
                            if (i % 25 === 0) {
                                const st =
                                    document.getElementById("recalc-status");
                                if (st)
                                    st.innerText = `Recalculating Zones... ${Math.round((i / cityIds.length) * 100)}%`;
                                await new Promise((r) => setTimeout(r, 5));
                            }
                        }

                        const st = document.getElementById("recalc-status");
                        if (st) {
                            st.innerText = "Zones & Boundaries Active";
                            st.className =
                                "mt-2 text-[10px] font-bold text-emerald-400";
                            setTimeout(() => st.remove(), 5000);
                        }
                    })();

                    return;
                }

                currentSnapshot = snap;

                // Remove active classes
                document
                    .querySelectorAll("#snapshot-list > div")
                    .forEach((el) =>
                        el.classList.remove("border-blue-500", "bg-gray-800"),
                    );
                const activeEl = document.getElementById(`snap-${snap.id}`);
                if (activeEl)
                    activeEl.classList.add("border-blue-500", "bg-gray-800");

                // Update UI
                document.getElementById("selected-snap-title").textContent =
                    snap.name ||
                    `${snap.cityId.toUpperCase()} - ${new Date(snap.created).toLocaleTimeString()}`;
                // Calculate Stats
                const counts = {
                    monster: 0,
                    shop: 0,
                    vault: 0,
                    castle: 0,
                    citadel: 0,
                    other: 0,
                };
                const levels = { min: 999, max: 0, avg: 0, sum: 0 };
                const objects = snap.objects || [];

                // Distribution Maps
                const monsterStats = {},
                    shopStats = {},
                    vaultStats = {},
                    castleStats = {},
                    citadelStats = {};
                window.zoneNames = {};
                let zoneCount = 0;
                let geoFeatures = [];

                if (snap.zones) {
                    try {
                        const z =
                            typeof snap.zones === "string"
                                ? JSON.parse(snap.zones)
                                : snap.zones;
                        if (z.features) {
                            geoFeatures = z.features;
                            zoneCount = geoFeatures.length;
                            geoFeatures.forEach((f, idx) => {
                                // Get zone ID - UNIQUE identifier (exclude name!)
                                let id =
                                    f.properties?.citadelId ||
                                    f.properties?.id ||
                                    f.id;

                                // If ID is missing or generic/non-unique, use index fallback
                                const checkId = String(id || "")
                                    .trim()
                                    .toLowerCase();
                                if (
                                    !id ||
                                    checkId === "citadel" ||
                                    checkId === "castle" ||
                                    checkId === "zone"
                                ) {
                                    id = `zone_${idx}`;
                                }

                                // Get display name
                                let name =
                                    f.properties?.name ||
                                    f.properties?.citadelName ||
                                    f.properties?.label ||
                                    id;

                                // If name is generic "Citadel", append ID or index to distinguish
                                if (name === "Citadel")
                                    name = `${name} ${idx + 1}`;

                                window.zoneNames[id] = name;

                                // Store the ID back in properties for consistency (FORCE UPDATE)
                                f.properties.citadelId = id;

                                // Initialize with 0 to ensure they appear in the list
                                monsterStats[id] = 0;
                                shopStats[id] = 0;
                                castleStats[id] = 0;
                                citadelStats[id] = 0;
                            });
                        }
                    } catch (e) {
                        console.error("Error parsing stats zones:", e);
                    }
                }

                objects.forEach((o, idx) => {
                    // 1. Identify Category
                    const isCitadel =
                        o.icon === "🏯" ||
                        (o.name && o.name.includes("Citadel")) ||
                        (o.templateId && o.templateId.includes("citadel"));

                    // 2. Population Counts
                    if (isCitadel) counts.citadel++;
                    else if (o.type === "monster") counts.monster++;
                    else if (o.type === "shop") counts.shop++;
                    else if (o.type === "vault") counts.vault++;
                    else if (o.type === "castle") counts.castle++;
                    else counts.other++;

                    // 3. Level stats
                    const lvl = o.level || 1;
                    if (lvl < levels.min) levels.min = lvl;
                    if (lvl > levels.max) levels.max = lvl;
                    levels.sum += lvl;

                    // 4. Determine Logical Zone (SPATIAL ONLY - Ignore stored zoneId for accuracy)
                    let zid = null;

                    // Always auto-assign zoneId using spatial check if zones exist
                    if (geoFeatures.length > 0 && window.turf) {
                        const point = [o.lng, o.lat];
                        let found = null;

                        for (const f of geoFeatures) {
                            try {
                                const isInside =
                                    window.turf.booleanPointInPolygon(point, f);
                                if (isInside) {
                                    found = f;
                                    break;
                                }
                            } catch (e) {
                                // Silently continue - some features may have invalid geometry
                            }
                        }

                        if (found) {
                            // Use the citadelId that was set during initialization
                            zid =
                                found.properties.citadelId ||
                                found.properties.id ||
                                found.id;

                            // Apply same fallback logic as above
                            if (
                                !zid ||
                                zid === "Citadel" ||
                                zid === "Castle" ||
                                zid === "Zone"
                            ) {
                            }

                            zid = found.properties.citadelId || found.id;

                            if (zid) o.zoneId = zid;
                        }
                    }

                    if (!zid) zid = "Outside Territories";

                    // 5. Add to Distribution
                    const target = isCitadel
                        ? citadelStats
                        : o.type === "monster"
                          ? monsterStats
                          : o.type === "shop"
                            ? shopStats
                            : o.type === "vault"
                              ? vaultStats
                              : o.type === "castle"
                                ? castleStats
                                : null;
                    if (target) {
                        target[zid] = (target[zid] || 0) + 1;
                    }
                });

                levels.avg = objects.length
                    ? (levels.sum / objects.length).toFixed(1)
                    : 0;
                if (levels.min === 999) levels.min = 0;

                const mapper = (map) =>
                    Object.entries(map).map(([id, count]) => ({ id, count }));
                const monsterDist = mapper(monsterStats);
                const shopDist = mapper(shopStats);
                const vaultDist = mapper(vaultStats);
                const castleDist = mapper(castleStats);
                const citadelDist = mapper(citadelStats);

                if (zoneCount === 0) {
                    const uniqueIds = new Set([
                        ...Object.keys(monsterStats),
                        ...Object.keys(shopStats),
                        ...Object.keys(vaultStats),
                        ...Object.keys(castleStats),
                        ...Object.keys(citadelStats),
                    ]);
                    uniqueIds.delete("Outside Territories");
                    zoneCount = uniqueIds.size;
                }

                window.currentZoneStats = {
                    monsters: monsterDist,
                    shops: shopDist,
                    vaults: vaultDist,
                    castles: castleDist,
                    citadels: citadelDist,
                };
                window.activeStatsTab = "monsters";

                const detailsHtml = `
                            <div class="space-y-1.5">
                                <!-- Core Stats Grid -->
                                <div class="grid grid-cols-2 gap-1.5 text-[10px]">
                                    <div class="bg-gray-700/30 p-2 rounded-lg border border-gray-700/50">
                                        <span class="text-gray-500 block uppercase tracking-tighter">Snap ID</span>
                                        <span class="text-white font-mono font-bold">${snap.id ? snap.id.substring(0, 10) : "N/A"}</span>
                                    </div>
                                    <div class="bg-gray-700/30 p-2 rounded-lg border border-gray-700/50">
                                        <span class="text-gray-500 block uppercase tracking-tighter">City</span>
                                        <span class="text-white font-bold uppercase">${snap.cityId || "Unknown"}</span>
                                    </div>
                                    <div class="bg-gray-700/30 p-2 rounded-lg border border-gray-700/50">
                                        <span class="text-gray-500 block uppercase tracking-tighter">Type</span>
                                        <span class="text-white font-bold uppercase text-blue-400">${snap.type || "Mixed"}</span>
                                    </div>
                                    <div class="bg-gray-700/30 p-2 rounded-lg border border-gray-700/50">
                                        <span class="text-gray-500 block uppercase tracking-tighter">Date</span>
                                        <span class="text-white font-bold">${new Date(snap.created).toLocaleDateString()}</span>
                                    </div>
                                </div>

                                <!-- Object Counts -->
