                    const markerIcon = L.divIcon({
                        html: iconHtml,
                        className: "custom-tpl-icon",
                        iconSize: actualIconSize,
                        iconAnchor: actualIconAnchor,
                    });

                    const marker = L.marker([lat, lng], {
                        icon: markerIcon,
                        zIndexOffset: zIndex,
