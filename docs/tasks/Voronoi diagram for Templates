                                                    try {
                                                        const centroid =
                                                            window.turf.centroid(
                                                                polygon,
                                                            );
                                                        matchedCitadel =
                                                            window.turf.nearestPoint(
                                                                centroid,
                                                                points,
                                                            );
                                                    } catch {
                                                        matchedCitadel =
                                                            points.features[
                                                                idx
                                                            ];
                                                    }
                                                }

