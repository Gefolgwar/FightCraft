                                }
                            });
                        }
                    });

                    if (zones.length > 0) {
                        console.log(
                            `✅ Loaded ${zones.length} custom zones with valid geometry.`,
                        );

                        let cacheKey = cityId;
                        if (
                            currentSnapshot &&
