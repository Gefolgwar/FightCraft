                                    <i class="fas ${r.inside ? "fa-check-circle text-emerald-400" : "fa-times-circle text-red-400"} text-[10px]"></i>
                                    ${r.name}
                                </span>
                                <b class="${r.inside ? "text-emerald-400" : "text-red-400"} font-bold">${r.inside ? "INSIDE" : "OUTSIDE"}</b>
