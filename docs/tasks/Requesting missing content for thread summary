            function renderCityBoundary(rings) {
                if (!cityBoundaryLayerGroup || !rings) return;
                cityBoundaryLayerGroup.clearLayers();

                let latLngs;
                if (rings.length > 0 && Array.isArray(rings[0][0])) {
                    latLngs = rings.map((ring) =>
                        ring.map((p) => [p[1], p[0]]),
                    );
                } else {
                    latLngs = rings.map((p) => [p[1], p[0]]);
