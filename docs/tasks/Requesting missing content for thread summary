                L.polygon(latLngs, {
                    color: "#10b981",
                    weight: 4,
                    dashArray: "10, 15",
                    fillColor: "#10b981",
                    fillOpacity: 0.15,
                    interactive: false,
                }).addTo(cityBoundaryLayerGroup);
