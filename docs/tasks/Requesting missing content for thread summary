                } else if (tab === "citadels") {
                    btnCit.className =
                        "px-2 py-1 rounded-md text-[9px] font-bold bg-orange-600 text-white";
                } else if (tab === "boundaries") {
                    btnZon.className =
                        "px-2 py-1 rounded-md text-[9px] font-bold bg-emerald-600 text-white";
