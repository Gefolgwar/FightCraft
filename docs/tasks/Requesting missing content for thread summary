                          ? monsterStats
                          : o.type === "shop"
                            ? shopStats
                            : o.type === "vault"
                              ? vaultStats
                              : o.type === "castle"
                                ? castleStats
                                : null;
                    if (target) {
                        target[zid] = (target[zid] || 0) + 1;
                    }
                });

