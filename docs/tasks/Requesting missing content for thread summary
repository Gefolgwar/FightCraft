                    class="absolute bottom-6 left-6 z-[1001] w-12 h-12 bg-slate-800/90 backdrop-blur border border-blue-500/50 rounded-full flex items-center justify-center shadow-lg transition-all hover:bg-slate-700"
                >
                    <i class="fas fa-terminal text-blue-400 text-xl"></i>
                </button>

                <div
                    id="console-panel"
                    class="absolute bottom-20 left-6 z-[1002] hidden w-80 max-h-[300px] bg-gray-900/95 backdrop-blur border border-gray-700 rounded-xl shadow-2xl overflow-hidden flex flex-col"
                >
                    <div
                        class="p-3 border-b border-gray-700 flex justify-between items-center bg-gray-800/50"
                    >
                        <h3
                            class="font-bold text-blue-400 text-xs tracking-wider flex items-center gap-2"
                        >
                            <i class="fas fa-terminal text-[10px]"></i>
                            OPERATION LOG
                        </h3>
                        <div class="flex gap-2">
