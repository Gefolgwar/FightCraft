                    if (typesPresent.has("vault"))
                        iconsHtml +=
                            '<i class="fas fa-box text-emerald-400 ml-1" title="Vaults"></i>';
                    if (hasCastle)
                        iconsHtml +=
                            '<i class="fas fa-chess-rook text-blue-400 ml-1" title="Castles"></i>';
                    if (hasCitadel)
                        iconsHtml +=
                            '<span class="ml-1 text-lg leading-none" title="Citadels">🏯</span>';

                    if (!iconsHtml)
                        iconsHtml =
