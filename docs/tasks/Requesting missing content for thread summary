            function initMap() {
                if (map) map.remove();

                // USE CANVAS RENDERER FOR PERFORMANCE (Same as main map)
                map = L.map("map", {
                    renderer: L.canvas(),
                    preferCanvas: true,
                }).setView([52.52, 13.405], 12); // Default Berlin

                L.tileLayer(
                    "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
