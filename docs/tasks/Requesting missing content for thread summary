                districtLayerGroup.clearLayers();

                const bounds = L.latLngBounds();

                districts.forEach((d) => {
                    try {
                        const poly = L.polygon(d.points, {
                            color: "#FFFF00",
                            weight: 1.5,
                            fillOpacity: 0.1,
                            fillColor: "#FFFF00",
