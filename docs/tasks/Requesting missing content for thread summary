                    </div>
                    <div
                        id="console-log"
                        class="flex-1 p-3 font-mono text-[10px] text-gray-400 overflow-y-auto leading-relaxed scrollbar-thin scrollbar-thumb-gray-700"
                    >
                        <div class="text-gray-600 italic">
                            Waiting for operations...
