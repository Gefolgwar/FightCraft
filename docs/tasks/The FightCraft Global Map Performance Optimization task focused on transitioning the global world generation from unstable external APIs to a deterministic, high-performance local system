        idCounts[city.id]++;
        city.id = `${city.id}-${idCounts[city.id]}`;
    } else {
        idCounts[city.id] = 1;
    }
});

const fileContent = `export const WORLD_CITIES = ${JSON.stringify(mappedCities, null, 2)};\n`;
