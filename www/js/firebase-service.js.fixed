const firebaseConfig = {
    apiKey: "AIzaSyD_MmVmjrchLqGgl8h1Zr-7od9QHvYPlW4",
    authDomain: "fight-craft-3c3f0.firebaseapp.com",
    projectId: "fight-craft-3c3f0",
    storageBucket: "fight-craft-3c3f0.firebasestorage.app",
