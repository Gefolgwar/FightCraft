    }

    try {
        const { collection, doc, setDoc, serverTimestamp } = await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js');

        // Generate random offset (-0.01 to +0.01 degrees, ~1km radius)
        const offsetLat = (Math.random() - 0.5) * 0.02;
        const offsetLng = (Math.random() - 0.5) * 0.02;

        const testCharacterName = `TestPlayer${Math.floor(Math.random() * 1000)}`;
        const adminUID = auth.currentUser.uid;

        const testCharacterData = {
            player: {
                name: testCharacterName,
                userName: 'TEST_PLAYER', // Marker for test players
                userEmail: 'test@player.local',
                avatar: 'ðŸ¤–',
                level: 1,
                xp: '0',
                xpToNext: '500',
                hp: 100,
                maxHp: 100,
                gold: Math.floor(Math.random() * 100),
                strength: 5,
                agility: 5,
                intuition: 5,
                vitality: 5,
                intellect: 5,
                wisdom: 5,
                statPoints: 0,
                regenRate: 0,
                lastDamageTime: 0,
                interactionRadius: 7
            },
            equipment: {
                helmet: null,
                armor: null,
                sword: null,
                shield: null,
                boots: null,
                gloves: null,
                belt: null
            },
            inventory: [],
            position: {
                lat: (gameState?.player?.position?.lat || 50.4501) + offsetLat,
                lng: (gameState?.player?.position?.lng || 30.5234) + offsetLng
            },
            settings: {
                sound: true,
                notifications: true,
                fog: true,
                vibration: false
            },
            quests: {
                monstersKilled: 0,
                itemsCollected: 0,
                uniquesKilled: 0,
                distanceTraveled: 0
            },
            debug: {
                enabled: false,
                moveSpeed: 1
            },
            inactiveMonsters: {},
            isTestPlayer: true, // Flag to identify test players
            createdAt: serverTimestamp(),
            lastSave: serverTimestamp()
        };

        // Save as character under admin's account
        const charactersRef = collection(db, "users", adminUID, "characters");
        const newCharRef = doc(charactersRef);
        await setDoc(newCharRef, testCharacterData);

        console.log(`âœ… Test character created: ${testCharacterName} [${newCharRef.id}] under admin ${adminUID.substring(0, 12)}...`);
