};

// Initialize Firebase
let app;
let db;
let auth;
let currentUser = null;
let userRole = 'player'; // default: 'player', 'moderator', 'admin'
let onlinePlayersCount = 0;

export async function initFirebase() {
    console.log('ðŸ”¥ Firebase: Initializing...');
    const start = Date.now();

    try {
        app = initializeApp(firebaseConfig);
        db = getFirestore(app);
        auth = getAuth(app);
        window.firebaseFirestore = { collectionGroup, query, onSnapshot };

        return new Promise((resolve) => {
            console.log('â³ Waiting for Firebase Auth State...');
            const timer = setTimeout(() => {
                const duration = ((Date.now() - start) / 1000).toFixed(1);
                console.warn(`âš ï¸ Auth check timed out after ${duration}s. Resolution: Force Login UI.`);
                window.location.href = 'login.html';
                resolve(false);
            }, 15000); // Increased to 15s for slow first-launch networks

            const unsubscribe = onAuthStateChanged(auth, async (user) => {
                clearTimeout(timer);
                const duration = ((Date.now() - start) / 1000).toFixed(1);

                if (user) {
                    currentUser = user;
                    console.log(`âœ… Firebase: Auth detected in ${duration}s for ${user.email}`);

                    // Realtime Role Sync
                    try {
                        console.log('â³ Syncing user profile/role...');

                        // FIRST: Load role synchronously to avoid race condition
                        const userDoc = await getDoc(doc(db, 'users', user.uid));

                        if (userDoc.exists()) {
                            const data = userDoc.data();
                            userRole = data.role || 'player';
                            console.log(`âœ… Initial Role Loaded: "${userRole}"`);

                            // Sync Missing Data
                            const updates = {};
                            if ((!data.displayName || data.displayName === 'No Name') && user.displayName) updates.displayName = user.displayName;
                            if (!data.email && user.email) updates.email = user.email;
                            if (Object.keys(updates).length > 0) {
                                updateDoc(doc(db, 'users', user.uid), updates).catch(e => console.warn("Update profile failed:", e));
                            }
                        } else {
                            console.log('ðŸ†• Creating new user profile...');
                            userRole = 'player';
                            await setDoc(doc(db, 'users', user.uid), {
                                email: user.email,
                                displayName: user.displayName || 'No Name',
                                role: 'player',
                                createdAt: serverTimestamp(),
                                lastLogin: serverTimestamp()
                            });
                        }

                        // SECOND: Set up real-time listener for role changes
                        const userUnsub = onSnapshot(doc(db, 'users', user.uid), (snapshot) => {
                            if (snapshot.exists()) {
                                const data = snapshot.data();
                                const oldRole = userRole;
                                userRole = data.role || 'player';

                                if (oldRole !== userRole) {
                                    console.log(`ðŸ”„ Role Updated: "${oldRole}" -> "${userRole}"`);
                                    if (window.refreshSettingsVisibility) {
                                        window.refreshSettingsVisibility();
                                    }
                                }
                            }
                        }, (error) => {
                            console.error("âŒ Firestore User Sync Error:", error);
                        });

                        // Update login timestamp
                        setDoc(doc(db, 'users', user.uid), { lastLogin: serverTimestamp() }, { merge: true });

                    } catch (e) {
                        console.error('Role sync error:', e);
                        userRole = 'player'; // Safe fallback
                    }

                    resolve(true);

                } else {
                    console.log(`â„¹ï¸ Firebase: No user detected in ${duration}s. Redirecting...`);
                    window.location.href = 'login.html';
                    resolve(false);
                }
            });
        });

    } catch (error) {
        console.error("Firebase init massive error:", error);
        showNotification('âŒ Firebase Error', 'error');
        return false;
    }
}

// Role Helpers
export function getUserRole() {
    return userRole;
}

export function isAdmin() {
    // DEV FIX: Always allow admin on localhost
    if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
        return true;
    }
    const res = userRole && userRole.toLowerCase() === 'admin';
    // console.log("DEBUG: isAdmin called, returning:", res); // Temporary debug
    return res;
}

export function isModerator() {
    return userRole && (userRole.toLowerCase() === 'admin' || userRole.toLowerCase() === 'moderator');
}

export async function logout() {
    try {
        await signOut(auth);
        window.location.href = 'login.html';
    } catch (error) {
        console.error('Logout error:', error);
    }
}

export function getCurrentUser() {
    return currentUser;
}

export async function savePlayerToCloud(playerData) {
    if (!currentUser || !db) return;

    try {
        const userRef = doc(db, "users", currentUser.uid);

        // Prepare data for cloud (remove non-serializable stuff if any)
        const dataToSave = {
            ...playerData,
            lastSave: serverTimestamp(),
            updatedAt: new Date().toISOString()
        };

        // We use setDoc with merge to update or create
        await setDoc(userRef, dataToSave, { merge: true });
        console.log('Cloud save complete');
    } catch (error) {
        console.error("Cloud save error:", error);
        addEventLog('Save failed: ' + error.message, 'error');
    }
}

export async function loadPlayerFromCloud() {
    if (!currentUser || !db) {
        console.warn("Cannot load: No user or DB");
        return null;
    }

    try {
        const userRef = doc(db, "users", currentUser.uid);
        const docSnap = await getDoc(userRef);

        if (docSnap.exists()) {
            console.log("Cloud data found:", docSnap.data());
            return docSnap.data();
        } else {
            console.log("No cloud data found (new player)");
            return null;
        }
    } catch (error) {
        console.error("Cloud load error:", error);
        return null;
    }
}

/**
 * Load any player's data by ID (for character switching in debug mode)
 * @param {string} characterId - Character ID
 * @param {string} ownerUID - Owner user ID (if loading from characters subcollection)
 */
export async function loadPlayerDataById(characterId, ownerUID = null) {
    if (!db) {
        console.error('Cannot load player: DB not initialized');
        return null;
    }

    try {
        const { doc, getDoc } = await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js');

        let docRef;

        if (ownerUID) {
            // Load from characters subcollection
            docRef = doc(db, "users", ownerUID, "characters", characterId);
        } else {
            // Fallback: try loading as old structure (standalone user)
            docRef = doc(db, "users", characterId);
        }

        const docSnap = await getDoc(docRef);

        if (docSnap.exists()) {
            const data = docSnap.data();
            console.log(`âœ… Loaded character data: ${characterId.substring(0, 12)}... (owner: ${ownerUID?.substring(0, 12) || 'self'})`);
            return data;
        } else {
            console.warn(`No data found for character: ${characterId} (owner: ${ownerUID || 'N/A'})`);
            return null;
        }
    } catch (error) {
        console.error("Error loading player data:", error);
        return null;
    }
}

export async function updatePlayerLocation(lat, lng) {
    if (!currentUser || !db) return;

    // Optimized location update (could be separate collection or RTDB in future)
    const userRef = doc(db, "users", currentUser.uid);
    try {
        await updateDoc(userRef, {
            position: { lat, lng },
            lastLocationUpdate: serverTimestamp()
        });
    } catch (e) {
        // Silent fail for location updates to avoid spam
    }
}

export function subscribeToPlayers(onUpdate) {
    if (!db) return () => { };

    // Use Collection Group query to get ALL characters from all users
    // This reads from users/{uid}/characters/{charId}

    try {
        // Query all documents in ANY "characters" collection
        const q = query(collectionGroup(db, "characters"));

        const unsubscribe = onSnapshot(q, (snapshot) => {
            const players = [];
            const currentUserId = getCurrentUser()?.uid;

            snapshot.forEach((doc) => {
                const data = doc.data();
                const parentPath = doc.ref.parent.parent; // Get parent user document
                const userId = parentPath?.id;
                const name = data.player?.name || 'Unknown';

                // GHOST FILTER: 
                // If it's a TestPlayer, ONLY show it if it belongs to YOU (currentUserId)
                // This hides ghosts from other users/old database entries
                const isTestPlayer = data.isTestPlayer || name.includes('TestPlayer');
                if (isTestPlayer && userId !== currentUserId) {
                    // Skip foreign test players (ghosts)
                    return;
                }

                // Validate data
                if (data.position && data.position.lat && data.position.lng) {
                    players.push({
                        id: doc.id, // Character ID
                        userId: userId, // User ID
                        position: data.position,
                        name: name,
                        level: data.player?.level || 1,
                        avatar: data.player?.avatar || 'ðŸ§™',
                        isSelf: userId === currentUserId && (doc.id === window._currentCharacterId || doc.id === window._currentlyPlayingCharacterId),
                        isTestPlayer: isTestPlayer
                    });
                }
            });

            onlinePlayersCount = players.length;
            console.log(`ðŸ“¡ Active characters: ${onlinePlayersCount}`, players.map(p => `${p.name} (${p.isSelf ? 'YOU' : 'other'})`));
            onUpdate(players);
        }, (error) => {
            console.warn("Player subscription error:", error);
            // Fallback to legacy if collection group fails
            return subscribeToPlayersLegacy(onUpdate);
        });

        return unsubscribe;
    } catch (error) {
        console.error('Collection Group query failed:', error);
        return subscribeToPlayersLegacy(onUpdate);
    }
}

/**
 * Legacy player subscription (for backward compatibility)
 * Reads from old structure: users/{uid}
 */
function subscribeToPlayersLegacy(onUpdate) {
    if (!db) return () => { };

    const q = query(collection(db, "users"));

    const unsubscribe = onSnapshot(q, (snapshot) => {
        const players = [];
        snapshot.forEach((doc) => {
            const data = doc.data();
            const name = data.player?.name || 'Unknown';

            // GHOST FILTER: Ignore ANY TestPlayer in legacy root collection
            // Because new TestPlayers live in subcollections
            if (name.includes('TestPlayer')) return;

            if (data.position && data.position.lat && data.position.lng) {
                players.push({
                    id: doc.id,
                    position: data.position,
                    name: name,
                    level: data.player?.level || 1,
                    avatar: data.player?.avatar || 'ðŸ§™',
                    isSelf: doc.id === getCurrentUser()?.uid
                });
            }
        });

        onlinePlayersCount = players.length;
        console.log(`ðŸ“¡ Active players (legacy): ${onlinePlayersCount}`);
        onUpdate(players);
    });

    return unsubscribe;
}

// ==================== MULTIPLAYER DEBUG FUNCTIONS ====================

/**
 * Get all players for debug dropdown (ONLY TEST PLAYERS)
 * Reads from NEW structure: users/{uid}/characters/{charId}
 */
export async function getAllPlayersForDebug() {
    if (!db) return [];

    try {
        // Use Collection Group query to get ALL characters
        const q = query(collectionGroup(db, "characters"));
        const snapshot = await getDocs(q);

        const players = [];
        const currentUserId = currentUser?.uid;

        snapshot.forEach((doc) => {
            const data = doc.data();

            // ONLY include test players in debug panel
            if (data.isTestPlayer !== true) {
                return; // Skip non-test players
            }

            const parentPath = doc.ref.parent.parent; // Get parent user document
            const userId = parentPath?.id;

            players.push({
                id: doc.id, // Character ID
                userId: userId, // User ID (for reference)
                name: data.player?.name || 'Unknown',
                level: data.player?.level || 1,
                avatar: data.player?.avatar || 'ðŸ§™',
                position: data.position || { lat: 0, lng: 0 },
                isSelf: false, // Test players are never "self"
                isTestPlayer: true,
                lastUpdate: data.lastSave
            });
        });

        console.log(`ðŸ“‹ Found ${players.length} TEST characters for debug`);
        return players;
    } catch (error) {
        console.error("Error loading characters for debug:", error);
        return [];
    }
}

/**
 * Load test players to map immediately (for instant display on game start)
 */
export async function loadTestPlayersToMap() {
    try {
        console.log('â³ Loading test players from Firebase...');

        // Show loading in Multi-Admin panel
        const countEl = document.getElementById('mp-online-count');
        if (countEl) countEl.textContent = 'â³';

        const testPlayers = await getAllPlayersForDebug();

        if (testPlayers.length === 0) {
            console.log('ðŸ“­ No test players to load');
            if (countEl) countEl.textContent = '0';
            return;
        }

        console.log(`ðŸ“¦ Loading ${testPlayers.length} test players to map...`);

        // Dynamically import map module
        const { otherPlayerMarkers, createPlayerMarker } = await import('./map.js');

        let loaded = 0;
        testPlayers.forEach(player => {
            // Only create if doesn't exist
            if (!otherPlayerMarkers[player.id] && player.position) {
                otherPlayerMarkers[player.id] = createPlayerMarker(
                    player.position.lat,
                    player.position.lng,
                    player.name,
                    player.avatar,
                    player.id,
                    player.level,
                    true // isTestPlayer
                );
                loaded++;
                console.log(`  âœ… ${player.name} loaded`);
            }
        });

        console.log(`âœ… ${loaded} test players loaded to map`);
        if (countEl) countEl.textContent = loaded.toString();
    } catch (error) {
        console.error('âŒ Error loading test players:', error);
        const countEl = document.getElementById('mp-online-count');
        if (countEl) countEl.textContent = 'âŒ';
    }
}

/**
