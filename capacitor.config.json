{
  "appId": "com.fightcraft.game",
  "appName": "FightCraft",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1a1a2e",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "spinnerColor": "#8b5cf6"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1a1a2e"
    },
    "Geolocation": {
      "requestPermissions": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
